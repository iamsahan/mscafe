{
  "name": "tax-education-backend",
  "version": "1.0.0",
  "description": "Backend API for Tax Education & Financial Services Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop mscafe-api",
    "restart": "pm2 restart mscafe-api",
    "status": "pm2 status",
    "logs": "pm2 logs mscafe-api",
    "monitor": "pm2 monit",
    "deploy": "bash ../scripts/deploy.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "node utils/seedDatabase.js",
    "migrate": "node utils/migrate.js",
    "health": "curl http://localhost:5000/health"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2",
    "nodemailer": "^6.9.4",
    "sequelize": "^6.32.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "pm2": "^6.0.8",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "tax-education",
    "financial-services",
    "express",
    "mysql",
    "api"
  ],
  "author": "Tax Education Platform",
  "license": "MIT"
}
