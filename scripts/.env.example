# MSCafe Backend Environment Variables
# Copy this file to your VPS at ~/mscafe/backend/.env

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=msc
DB_USER=mscafe_user
DB_PASSWORD=your_secure_app_password

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration (generate a secure secret)
JWT_SECRET=your_very_secure_jwt_secret_key_here_change_this

# File Upload Configuration
UPLOAD_PATH=./uploads

# Optional: Email Configuration (if needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Optional: Other configurations
# CORS_ORIGIN=http://your-domain.com
# SESSION_SECRET=your_session_secret_here
